# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_HOST=mongodb
MONGO_PORT=27017

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Config Server
CONFIG_SERVER_URI=http://config-service:8888

# Eureka
EUREKA_URI=http://registry-service:8761/eureka

# JWT
JWT_SECRET=change-me-to-a-long-random-string-at-least-256-bits
JWT_ACCESS_TOKEN_EXPIRATION=1800000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Default Admin (seeded by user-service on first startup)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=change-me-strong-password